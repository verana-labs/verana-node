{
  "name": "@verana-labs/verana-types",
  "version": "0.9.1",
  "description": "Generated TypeScript protobuf codecs for the Verana blockchain.",
  "license": "AGPL-3.0-only",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./signing": {
      "types": "./dist/signing.d.ts",
      "require": "./dist/signing.js",
      "default": "./dist/signing.js"
    },
    "./codec/*": {
      "types": "./dist/codec/*.d.ts",
      "require": "./dist/codec/*.js",
      "default": "./dist/codec/*.js"
    },
    "./amino-converter/*": {
      "types": "./dist/amino-converter/*.d.ts",
      "require": "./dist/amino-converter/*.js",
      "default": "./dist/amino-converter/*.js"
    },
    "./helpers/*": {
      "types": "./dist/helpers/*.d.ts",
      "require": "./dist/helpers/*.js",
      "default": "./dist/helpers/*.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prepare": "npm run build",
    "smoke": "node scripts/smoke-package.cjs"
  },
  "dependencies": {
    "long": "5.3.2",
    "protobufjs": "7.2.6"
  },
  "devDependencies": {
    "@cosmjs/proto-signing": "0.32.3",
    "@cosmjs/stargate": "0.32.3",
    "ts-proto": "1.181.2",
    "typescript": "5.7.3"
  },
  "peerDependencies": {
    "@cosmjs/proto-signing": "^0.32.3",
    "@cosmjs/stargate": "^0.32.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/verana-labs/verana.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
