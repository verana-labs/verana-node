    "test:gf-add-doc": "npx tsx src/journeys/gfAddGovernanceFrameworkDocument.ts",
    "test:gf-increase-version": "npx tsx src/journeys/gfIncreaseActiveGovernanceFrameworkVersion.ts",
    "test:de-grant-cs-auth": "npx tsx src/journeys/deGrantCsOperatorAuthorization.ts",
