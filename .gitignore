# Ignore build directory
build/

# Ignore binary
/verana

# Ignore macOS system files
.DS_Store
**/.DS_Store

# Ignore Go build and test files
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out

# Ignore dependency directories (add if you're not committing these)
vendor/

# Ignore IDE specific files (optional, add if you use these IDEs)
.idea/
.vscode/
*.swp
*.swo

.s3cfg
.secrets*
.env

# Test harness
testharness/journey_results/*

# TypeScript test harness runtime artifacts
ts-proto/test/journey_results/*.json
!ts-proto/test/journey_results/.gitkeep
ts-proto/test/out/

# Compiled binaries in ts-proto
ts-proto/cmd

# Agent / planning scratch (never commit)
docs/superpowers/
.worktrees/
.claude-agents/audit/
.claude
journey_results/
